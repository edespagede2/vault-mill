---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const executives = await getCollection("executives");

  return Promise.all(
    executives
      .filter((executive) => executive.data.published)
      .map(async (executive) => {
        const { Content } = await render(executive);

        return {
          params: {
            slug: executive.data.slug,
          },
          props: {
            executive,
            Content,
          },
        };
      })
  );
}

const { executive, Content } = Astro.props;
---

<BaseLayout title={executive.data.name}>
  <section class="profile">
    <header class="profile-header">
      <h1>{executive.data.name}</h1>

      <p class="profile-title">
        {executive.data.title}
      </p>

      <p class="profile-company">
        {executive.data.company_id.replace("company-", "").replace("-", " ")}
      </p>
    </header>

    <section class="profile-body">
      <Content />
    </section>
  </section>
</BaseLayout>