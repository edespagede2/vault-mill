---
import { getCollection } from "astro:content";
import { resolveDomain } from "../lib/domainResolver";

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MillNameCard from "../components/MillNameCard.astro";

console.log("Host header:", Astro.request.headers.get("host"));
console.log("Astro.url.hostname:", Astro.url.hostname);

const host = Astro.request.headers.get("host") ?? "";

const executive = await resolveDomain(host);

if (executive) {
  return Astro.redirect(`/millnames/${executive.data.slug}`, 307);
}

const normalized = host
  .toLowerCase()
  .replace(/:\d+$/, "")
  .replace(/^www\./, "");

if (
  normalized !== "vaultmill.com" &&
  normalized !== ""
) {
  return Astro.redirect("https://www.vaultmill.com", 301);
}

const executives = await getCollection("millnames");

executives.sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout
  title="VaultMill"
  description="Structured executive profiles built from publicly available information."
>
  <Hero />

  <section id="featured" class="featured">
    <h2>Featured Executives</h2>

    <div class="millname-grid">
      {executives.map((executive) => (
        <MillNameCard millname={executive} />
      ))}
    </div>
  </section>

  <section class="page">
    <h2>About VaultMill</h2>

    <p>
      VaultMill is building a structured knowledge platform for business
      leaders. Today the focus is executive profiles. Future releases
      will expand to companies, boards, organizations, industries,
      places, and the relationships that connect them.
    </p>
  </section>
</BaseLayout>