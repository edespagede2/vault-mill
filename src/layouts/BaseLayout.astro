---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "VaultMill",
  description = "Structured intelligence for executives, companies, boards, organizations, and industries."
} = Astro.props;
---

<!DOCTYPE html>

<html lang="en">

<head>

  <meta charset="utf-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="theme-color"
    content="#ffffff"
  />

  <meta
    name="color-scheme"
    content="light"
  />

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

</head>

<body>

  <Header />

  <main>

    <slot />

  </main>

  <Footer />

</body>

</html>